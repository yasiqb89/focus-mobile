{
  "expo": {
    "name": "Focus",
    "slug": "focus-mobile",
    "scheme": "focus",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.focus.mobile"
    },
    "android": {
      "package": "app.focus.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#fdf8f8"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
